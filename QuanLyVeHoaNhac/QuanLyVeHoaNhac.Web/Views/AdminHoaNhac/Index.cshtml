@model List<QuanLyVeHoaNhac.Models.HoaNhac>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BACKSTAGE ADMIN - Tổng Quan Hệ Thống</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
            body {
                background-color: #0d0e10;
                color: #ffffff;
                font-family: 'Segoe UI', system-ui, sans-serif;
                overflow-x: hidden;
            }

            /* 1. TOPBAR CỐ ĐỊNH */
            .topbar {
                background-color: #121316;
                border-bottom: 1px solid #1f2226;
                height: 70px;
                padding: 0 24px;
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                z-index: 1030;
            }

            .logo-text {
                color: #00FF00;
                font-weight: bold;
                font-size: 22px;
                letter-spacing: 1px;
                text-decoration: none;
            }

            .top-nav-link {
                color: #8a8d93;
                font-weight: 600;
                text-decoration: none;
                font-size: 16px;
                transition: 0.2s;
                cursor: pointer;
            }

                .top-nav-link:hover, .top-nav-link.active {
                    color: #00FF00;
                }

            .search-box {
                background-color: #1a1c20;
                border: 1px solid #2d3138;
                color: white;
                border-radius: 6px;
                font-size: 14px;
                padding: 6px 12px;
                max-width: 240px;
            }

                .search-box::placeholder {
                    color: #5a5e66;
                }

            .admin-badge {
                background-color: #00FF00;
                color: black;
                font-size: 10px;
                font-weight: bold;
                padding: 2px 6px;
                border-radius: 4px;
            }

            /* 2. SIDEBAR DỌC TRÁI */
            .sidebar {
                background-color: #121316;
                width: 260px;
                position: fixed;
                top: 70px;
                bottom: 0;
                left: 0;
                border-right: 1px solid #1f2226;
                padding: 24px 16px;
                z-index: 1020;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
            }

            .portal-title {
                color: #00FF00;
                font-size: 15px;
                font-weight: 700;
                letter-spacing: 1px;
                margin-bottom: 2px;
            }

            .portal-subtitle {
                color: #5a5e66;
                font-size: 11px;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 1px;
                margin-bottom: 25px;
            }

            .side-menu-link {
                display: flex;
                align-items: center;
                gap: 12px;
                color: #8a8d93;
                text-decoration: none;
                padding: 12px 16px;
                border-radius: 6px;
                font-size: 14px;
                font-weight: 500;
                margin-bottom: 6px;
                transition: 0.2s;
                cursor: pointer;
            }

                .side-menu-link:hover {
                    background-color: rgba(255,255,255,0.03);
                    color: #fff;
                }

                .side-menu-link.active {
                    background-color: rgba(0, 255, 0, 0.08);
                    color: #00FF00;
                    border-left: 4px solid #00FF00;
                    border-radius: 0 6px 6px 0;
                    margin-left: -16px;
                    padding-left: 20px;
                }

            .btn-tab-active {
                background-color: #00FF00;
                color: black;
                font-weight: bold;
                font-size: 12px;
                border: none;
                padding: 6px 16px;
                border-radius: 4px;
            }

            .btn-tab-inactive {
                background-color: #212429;
                color: #8a8d93;
                font-size: 12px;
                border: none;
                padding: 6px 16px;
                border-radius: 4px;
            }

            /* 3. VÙNG NỘI DUNG CHÍNH (MAIN CONTAINER) */
            .main-wrapper {
                margin-left: 260px;
                margin-top: 70px;
                padding: 32px;
                min-height: calc(100vh - 70px);
                padding-bottom: 120px;
            }

            .page-title {
                font-size: 32px;
                font-weight: bold;
                color: #ffffff;
                letter-spacing: -0.5px;
            }

            .page-desc {
                color: #8a8d93;
                font-size: 14px;
            }

            .status-online {
                background-color: rgba(0,255,0,0.1);
                color: #00FF00;
                border: 1px solid rgba(0,255,0,0.2);
                font-size: 12px;
                padding: 6px 16px;
                border-radius: 20px;
                font-weight: 600;
                display: inline-flex;
                align-items: center;
                gap: 6px;
            }

            .status-dot {
                width: 6px;
                height: 6px;
                background-color: #00FF00;
                border-radius: 50%;
                box-shadow: 0 0 8px #00FF00;
            }

            /* 4. CÁC THẺ CARD SỐ LIỆU */
            .card-stat {
                background-color: #121316;
                border: 1px solid #1f2226;
                border-radius: 8px;
                padding: 20px;
                position: relative;
            }

            .card-stat-title {
                color: #8a8d93;
                font-size: 11px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

            .card-stat-value {
                font-size: 28px;
                font-weight: bold;
                color: white;
                margin-top: 8px;
            }

            .card-stat-sub {
                font-size: 12px;
                color: #00FF00;
                font-weight: 600;
                display: flex;
                align-items: center;
                gap: 4px;
                margin-top: 4px;
            }

            .card-stat-icon {
                position: absolute;
                top: 20px;
                right: 20px;
                font-size: 18px;
                color: #00FF00;
                background-color: rgba(0,255,0,0.08);
                width: 32px;
                height: 32px;
                border-radius: 6px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            /* 5. KHỐI ĐỒ THỊ & HOẠT ĐỘNG */
            .panel-custom {
                background-color: #121316;
                border: 1px solid #1f2226;
                border-radius: 8px;
                padding: 24px;
                height: 100%;
            }

            .panel-header-text {
                font-size: 18px;
                font-weight: bold;
                color: #fff;
                margin-bottom: 20px;
            }

            /* Đồ thị cột giả lập giống Figma */
            .chart-container {
                display: flex;
                align-items: flex-end;
                justify-content: space-between;
                height: 200px;
                padding-top: 20px;
                margin-top: 20px;
            }

            .chart-bar-wrapper {
                display: flex;
                flex-direction: column;
                align-items: center;
                flex: 1;
            }

            .chart-bar {
                width: 36px;
                background-color: #23262d;
                border-radius: 4px;
                transition: 0.3s;
                position: relative;
            }

                .chart-bar.active {
                    background-color: #00FF00;
                    box-shadow: 0 0 15px rgba(0,255,0,0.3);
                }

            .chart-label {
                font-size: 11px;
                color: #5a5e66;
                margin-top: 10px;
                font-weight: 600;
            }

            .chart-badge {
                background-color: #fff;
                color: black;
                font-size: 10px;
                font-weight: bold;
                padding: 2px 8px;
                border-radius: 4px;
                position: absolute;
                top: -28px;
                left: 50%;
                transform: translateX(-50%);
                white-space: nowrap;
            }

            /* Dòng hoạt động trực tiếp */
            .activity-item {
                display: flex;
                gap: 14px;
                margin-bottom: 20px;
                align-items: flex-start;
            }

            .activity-icon-wrapper {
                width: 32px;
                height: 32px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 14px;
                flex-shrink: 0;
            }

            .bg-bought {
                background-color: rgba(0,255,0,0.1);
                color: #00FF00;
            }

            .bg-verify {
                background-color: rgba(255,255,255,0.05);
                color: #8a8d93;
                border: 1px solid #2d3138;
            }

            .bg-warning-custom {
                background-color: rgba(255,77,77,0.1);
                color: #ff4d4d;
            }

            .activity-title {
                font-size: 13px;
                font-weight: bold;
                color: #fff;
                margin-bottom: 2px;
            }

            .activity-desc {
                font-size: 12px;
                color: #8a8d93;
                margin-bottom: 2px;
            }

            .activity-meta {
                font-size: 11px;
                color: #5a5e66;
            }

            /* Khối Banner Tour diễn */
            .banner-concert {
                background: linear-gradient(180deg, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.85) 100%), url('https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?q=80&w=1000&auto=format&fit=crop') center center;
                background-size: cover;
                border-radius: 8px;
                border: 1px solid #1f2226;
                padding: 24px;
                height: 180px;
                display: flex;
                flex-direction: column;
                justify-content: flex-end;
            }

            .badge-live {
                background-color: #00FF00;
                color: #000;
                font-size: 10px;
                font-weight: bold;
                padding: 2px 6px;
                border-radius: 4px;
                display: inline-block;
                width: max-content;
                margin-bottom: 8px;
            }

            .btn-outline-custom {
                background-color: transparent;
                border: 1px solid #2d3138;
                color: white;
                padding: 10px 20px;
                font-size: 13px;
                border-radius: 6px;
                font-weight: 500;
                text-decoration: none;
                width: 100%;
                display: block;
                text-align: center;
                transition: 0.2s;
            }

                .btn-outline-custom:hover {
                    background-color: white;
                    color: black;
                }

            /* CẤU TRÚC PHÂN HỆ SỰ KIỆN & BÁO CÁO BỔ SUNG */
            .table-custom th {
                color: #8a8d93;
                font-size: 12px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                border-bottom: 1px solid #1f2226;
                padding: 14px;
            }

            .table-custom td {
                padding: 14px;
                border-bottom: 1px solid #1f2226;
                color: #fff;
                font-size: 14px;
            }

            .btn-neon-action {
                background-color: rgba(0,255,0,0.1);
                color: #00FF00;
                border: 1px solid rgba(0,255,0,0.2);
                font-size: 12px;
                font-weight: bold;
                padding: 5px 12px;
                border-radius: 4px;
                text-decoration: none;
                transition: 0.2s;
            }

                .btn-neon-action:hover {
                    background-color: #00FF00;
                    color: #000;
                }

            .btn-add-concert {
                background-color: #00FF00;
                color: #000;
                font-weight: bold;
                border: none;
                padding: 8px 16px;
                border-radius: 6px;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                gap: 6px;
                font-size: 14px;
            }

            .progress-custom {
                background-color: #23262d;
                height: 8px;
                border-radius: 4px;
                overflow: hidden;
            }

            .progress-bar-neon {
                background-color: #00FF00;
                box-shadow: 0 0 8px #00FF00;
            }

            /* 6. FOOTER DƯỚI ĐÁY */
            .footer-dashboard {
                background-color: #0d0e10;
                border-top: 1px solid #1f2226;
                padding: 40px 32px;
                margin-left: 260px;
                margin-top: auto;
            }

            .footer-logo {
                color: #00FF00;
                font-weight: bold;
                font-size: 24px;
                margin-bottom: 12px;
            }

            .footer-heading {
                color: #fff;
                font-size: 14px;
                font-weight: bold;
                text-transform: uppercase;
                margin-bottom: 16px;
                letter-spacing: 0.5px;
            }

            .footer-link {
                color: #8a8d93;
                text-decoration: none;
                font-size: 13px;
                display: block;
                margin-bottom: 10px;
                transition: 0.2s;
            }

                .footer-link:hover {
                    color: #fff;
                }

            .footer-social-icon {
                color: #8a8d93;
                font-size: 18px;
                margin-right: 16px;
                transition: 0.2s;
            }

                .footer-social-icon:hover {
                    color: #00FF00;
                }

            /* ĐIỀU KHIỂN ĐÓNG MỞ TAB PANEL */
            .tab-panel-content {
                display: none;
            }

                .tab-panel-content.panel-active {
                    display: block;
                }
    </style>
</head>
<body>

    <div class="topbar d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-5">
            <a href="/AdminHoaNhac" class="logo-text">BACKSTAGE ADMIN</a>
            <div class="d-flex gap-4">
                <span onclick="toggleAdminTab('tongquan')" id="top-link-tongquan" class="top-nav-link active">TỔNG QUAN</span>
                <span onclick="toggleAdminTab('sukien')" id="top-link-sukien" class="top-nav-link">SỰ KIỆN</span>
                <span onclick="toggleAdminTab('baocao')" id="top-link-baocao" class="top-nav-link">BÁO CÁO</span>
            </div>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="position-relative">
                <input type="text" class="search-box" placeholder="Tìm kiếm sự kiện, nghệ sĩ...">
            </div>
            <a href="#" class="text-secondary fs-5 px-1"><i class="bi bi-bell"></i></a>
            <a href="#" class="text-secondary fs-5 px-1"><i class="bi bi-gear"></i></a>
            <div class="d-flex align-items-center gap-2 border-start border-secondary ps-3">
                <div class="text-end">
                    <div class="fw-bold text-white small">ADMIN</div>
                    <div class="text-muted" style="font-size: 10px;">Quản trị viên</div>
                </div>
                <div class="admin-avatar" style="background-color: #00FF00;"><i class="bi bi-person-fill text-dark"></i></div>
            </div>
        </div>
    </div>

    <div class="sidebar">
        <div>
            <div class="portal-title">ADMIN PORTAL</div>
            <div class="portal-subtitle">Management Console</div>

            <span onclick="toggleAdminTab('tongquan')" id="side-link-tongquan" class="side-menu-link active"><i class="bi bi-grid-1x2-fill"></i> TỔNG QUAN</span>
            <span onclick="toggleAdminTab('sukien')" id="side-link-sukien" class="side-menu-link"><i class="bi bi-calendar4-event"></i> SỰ KIỆN TRỰC TIẾP</span>
            <span onclick="toggleAdminTab('baocao')" id="side-link-baocao" class="side-menu-link"><i class="bi bi-bar-chart-line-fill"></i> DOANH SỐ VÉ & BÁO CÁO</span>
            <a href="#" class="side-menu-link"><i class="bi bi-people"></i> QUẢN LÝ NGƯỜI DÙNG</a>
            <a href="#" class="side-menu-link"><i class="bi bi-geo-alt"></i> BẢN ĐỒ ĐỊA ĐIỂM</a>
            <a href="#" class="side-menu-link"><i class="bi bi-journal-text"></i> NHẬT KÝ HỆ THỐNG</a>
        </div>
        <div>
            <div class="d-flex p-1 bg-dark rounded mb-4" style="background-color: #1a1c20 !important;">
                <button class="btn-tab-active w-50">TUẦN</button>
                <button class="btn-tab-inactive w-50">THÁNG</button>
            </div>
            <a href="#" class="side-menu-link"><i class="bi bi-person-circle"></i> TÀI KHOẢN</a>
            <a href="/AdminHoaNhac/Logout" class="side-menu-link text-danger"><i class="bi bi-box-arrow-left"></i> ĐĂNG XUẤT</a>
        </div>
    </div>

    <div class="main-wrapper">

        <div id="panel-tongquan" class="tab-panel-content panel-active">
            <div class="d-flex justify-content-between align-items-start mb-4">
                <div>
                    <h1 class="page-title">Tổng Quan Hệ Thống</h1>
                    <p class="page-desc m-0">Chào mừng bạn trở lại, Quản trị viên. Dưới đây là tóm tắt hoạt động của hệ thống trong tuần này.</p>
                </div>
                <div class="status-online">
                    <div class="status-dot"></div> HỆ THỐNG TRỰC TUYẾN
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-xl-3 col-sm-6">
                    <div class="card-stat">
                        <div class="card-stat-title">Tổng Doanh Thu</div>
                        <div class="card-stat-value">$2.4M</div>
                        <div class="card-stat-sub"><i class="bi bi-arrow-up-short"></i> +12.4%</div>
                        <div class="card-stat-icon"><i class="bi bi-cash"></i></div>
                    </div>
                </div>
                <div class="col-xl-3 col-sm-6">
                    <div class="card-stat">
                        <div class="card-stat-title">Vé Đã Bán</div>
                        <div class="card-stat-value">42,850</div>
                        <div class="card-stat-sub"><i class="bi bi-arrow-up-short"></i> +5.2%</div>
                        <div class="card-stat-icon"><i class="bi bi-ticket-perforated"></i></div>
                    </div>
                </div>
                <div class="col-xl-3 col-sm-6">
                    <div class="card-stat">
                        <div class="card-stat-title">Sự Kiện Đang Hoạt Động</div>
                        <div class="card-stat-value">@Model.Count</div>
                        <div class="text-muted small mt-1" style="font-size: 12px;">Tại 12 địa điểm</div>
                        <div class="card-stat-icon"><i class="bi bi-calendar-check"></i></div>
                    </div>
                </div>
                <div class="col-xl-3 col-sm-6">
                    <div class="card-stat">
                        <div class="card-stat-title">Người Dùng Mới</div>
                        <div class="card-stat-value">1,204</div>
                        <div class="card-stat-sub"><i class="bi bi-arrow-up-short"></i> +18.7%</div>
                        <div class="card-stat-icon"><i class="bi bi-person-plus"></i></div>
                    </div>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-lg-8">
                    <div class="panel-custom">
                        <div class="panel-header-text">Xu Hướng Doanh Thu</div>
                        <div class="chart-container">
                            <div class="chart-bar-wrapper"><div class="chart-bar" style="height: 70px;"></div><div class="chart-label">T2</div></div>
                            <div class="chart-bar-wrapper"><div class="chart-bar" style="height: 110px;"></div><div class="chart-label">T3</div></div>
                            <div class="chart-bar-wrapper"><div class="chart-bar" style="height: 60px;"></div><div class="chart-label">T4</div></div>
                            <div class="chart-bar-wrapper">
                                <div class="chart-bar active" style="height: 170px;">
                                    <div class="chart-badge">HỆ THỐNG TRỰC TUYẾN</div>
                                </div>
                                <div class="chart-label">T5</div>
                            </div>
                            <div class="chart-bar-wrapper"><div class="chart-bar" style="height: 120px;"></div><div class="chart-label">T6</div></div>
                            <div class="chart-bar-wrapper"><div class="chart-bar" style="height: 140px;"></div><div class="chart-label">T7</div></div>
                            <div class="chart-bar-wrapper"><div class="chart-bar" style="height: 95px;"></div><div class="chart-label">CN</div></div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="panel-custom">
                        <div class="panel-header-text">Hoạt Động Trực Tiếp</div>
                        <div class="activity-item">
                            <div class="activity-icon-wrapper bg-bought"><i class="bi bi-cart-fill"></i></div>
                            <div>
                                <div class="activity-title">VÉ ĐÃ ĐƯỢC MUA</div>
                                <div class="activity-desc">Khu A - Lễ hội Sân khấu chính - <span class="text-success">$150</span></div>
                                <div class="activity-meta">2 phút trước</div>
                            </div>
                        </div>
                        <div class="activity-item">
                            <div class="activity-icon-wrapper bg-verify"><i class="bi bi-check-circle-fill"></i></div>
                            <div>
                                <div class="activity-title">NGHỆ SĨ MỚI ĐÃ XÁC MINH</div>
                                <div class="activity-desc">Techno Voyager (Berlin)</div>
                                <div class="activity-meta">15 phút trước</div>
                            </div>
                        </div>
                        <div class="activity-item">
                            <div class="activity-icon-wrapper bg-bought"><i class="bi bi-credit-card-fill"></i></div>
                            <div>
                                <div class="activity-title">THANH TOÁN ĐÃ XỬ LÝ</div>
                                <div class="activity-desc">Địa điểm: Hội trường Underground</div>
                                <div class="activity-meta">45 phút trước</div>
                            </div>
                        </div>
                        <div class="activity-item">
                            <div class="activity-icon-wrapper bg-warning-custom"><i class="bi bi-exclamation-triangle-fill"></i></div>
                            <div>
                                <div class="activity-title">CẢNH BÁO TẮC NGHẼN CỔNG</div>
                                <div class="activity-desc">Cổng số 4: Thời gian chờ > 20 phút</div>
                                <div class="activity-meta">1 giờ trước</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="banner-concert">
                        <div class="badge-live">ĐANG DIỄN RA</div>
                        <h3 class="fw-bold m-0 text-white">Tour Diễn Neon Horizon</h3>
                        <p class="text-light small m-0" style="opacity:0.8;">Địa điểm: Cyber Dome Arena | 85% Công suất</p>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="panel-custom d-flex flex-column justify-content-between">
                        <div class="row text-center my-auto">
                            <div class="col-4">
                                <h4 class="fw-bold text-success">12.5k</h4>
                                <small class="text-secondary font-monospace" style="font-size: 11px;">LƯỢT CHECK-IN</small>
                            </div>
                            <div class="col-4">
                                <h4 class="fw-bold text-white">8.2k</h4>
                                <small class="text-secondary font-monospace" style="font-size: 11px;">TRONG KHU VỰC</small>
                            </div>
                            <div class="col-4">
                                <h4 class="fw-bold text-white">420</h4>
