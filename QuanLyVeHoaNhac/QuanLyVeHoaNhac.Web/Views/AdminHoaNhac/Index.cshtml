                    </div>
                </div>
            </div>
        </div>

        <div id="panel-sukien" class="tab-panel-content">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="page-title">Quản Lý Sự Kiện</h1>
                    <p class="page-desc m-0">Danh sách các đêm nhạc thực tế trong bộ nhớ giả lập.</p>
                </div>
                <a href="/AdminHoaNhac/Create" class="btn-add-concert"><i class="bi bi-plus-circle-fill me-1"></i> Thêm Đêm Nhạc Mới</a>
            </div>

            <div class="panel-custom">
                <div class="table-responsive">
                    <table class="table table-dark table-custom align-middle m-0">
                        <thead>
                            <tr>
                                <th>Mã Đêm Nhạc</th>
                                <th>Tên Buổi Hòa Nhạc</th>
                                <th>Địa Điểm Tổ Chức</th>
                                <th>Thời Gian Diễn Ra</th>
                                <th class="text-center">Hành Động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-success fw-bold">@item.Id</td>
                                    <td class="fw-bold">@item.TenHoaNhac</td>
                                    <td>@item.DiaDiem</td>
                                    <td>@item.ThoiGian.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-center">
                                        <a href="#" class="btn-neon-action text-warning me-2" style="border-color: rgba(255,193,7,0.2); background: rgba(255,193,7,0.05);">Sửa</a>
                                        <a href="/AdminHoaNhac/Delete/@item.Id" class="btn-neon-action text-danger" style="border-color: rgba(220,53,69,0.2); background: rgba(220,53,69,0.05);" onclick="return confirm('Tiến chắc chắn muốn xóa show này chứ?');">Xóa</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="panel-baocao" class="tab-panel-content">
            <div class="mb-4">
                <h1 class="page-title">Báo Cáo Hoạt Động</h1>
                <p class="page-desc m-0">Biểu đồ đo lường hiệu suất bán vé và cơ cấu tài chính show nhạc.</p>
            </div>

            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="panel-custom">
                        <div class="panel-header-text">Tiến Độ Bán Vé Thực Tế</div>
                        @foreach (var item in Model)
                        {
                            <div class="mb-4">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="fw-bold">@item.TenHoaNhac</span>
                                    <span class="text-success">80% (240/300 Vé)</span>
                                </div>
                                <div class="progress-custom">
                                    <div class="progress-bar progress-bar-neon h-100" style="width: 80%"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="panel-custom">
                        <div class="panel-header-text">Phân Chia Cơ Cấu Doanh Thu</div>
                        <ul class="list-unstyled m-0">
                            <li class="d-flex justify-content-between py-3 border-bottom border-secondary">
                                <span class="text-secondary"><i class="bi bi-circle-fill text-success me-2" style="font-size: 8px;"></i> Doanh số Vé VIP (Khán đài A)</span>
                                <span class="fw-bold">50,000,000đ</span>
                            </li>
                            <li class="d-flex justify-content-between py-3 border-bottom border-secondary">
                                <span class="text-secondary"><i class="bi bi-circle-fill text-info me-2" style="font-size: 8px;"></i> Doanh số Vé Thường (GA)</span>
                                <span class="fw-bold">20,000,000đ</span>
                            </li>
                            <li class="d-flex justify-content-between py-3">
                                <span class="text-secondary"><i class="bi bi-circle-fill text-warning me-2" style="font-size: 8px;"></i> Quầy dịch vụ F&B sân bãi</span>
                                <span class="fw-bold">5,000,000đ</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="footer-dashboard">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="footer-logo">BACKSTAGE</div>
                <p class="text-secondary small" style="max-width: 280px;">Kết nối bạn với những cung bậc cảm xúc âm nhạc đỉnh cao.</p>
            </div>
            <div class="col-md-3">
                <div class="footer-heading">Khám Phá</div>
                <a href="#" class="footer-link">Tất cả sự kiện</a>
                <a href="#" class="footer-link">Địa điểm</a>
            </div>
            <div class="col-md-3">
                <div class="footer-heading">Hỗ Trợ</div>
                <a href="#" class="footer-link">Điều khoản sử dụng</a>
                <a href="#" class="footer-link">Chính sách bảo mật</a>
            </div>
            <div class="col-md-2">
                <div class="footer-heading">Kết Nối</div>
                <div class="d-flex">
                    <a href="#" class="footer-social-icon"><i class="bi bi-globe"></i></a>
                    <a href="#" class="footer-social-icon"><i class="bi bi-share-fill"></i></a>
                </div>
            </div>
        </div>
        <div class="text-muted mt-5" style="font-size: 11px;">
            © 2026 BACKSTAGE ENTERTAINMENT. BẢO LƯU MỌI QUYỀN. ALL ACCESS GRANTED.
        </div>
    </div>

    <script>
            function toggleAdminTab(targetTab) {
                // Ẩn tất cả panels dữ liệu
                document.querySelectorAll('.tab-panel-content').forEach(p => {
                    p.classList.remove('panel-active');
                });
                // Gỡ bỏ trạng thái sáng nút ở menu
                document.querySelectorAll('.top-nav-link, .side-menu-link').forEach(link => {
                    link.classList.remove('active');
                });

                // Kích hoạt panel được chọn
                document.getElementById('panel-' + targetTab).classList.add('panel-active');
                // Bật sáng các nút tương ứng ở Topbar và Sidebar
                document.getElementById('top-link-' + targetTab).classList.add('active');
                document.getElementById('side-link-' + targetTab).classList.add('active');
            }
    </script>
</body>
</html>